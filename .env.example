# LLM Provider: openai | anthropic (default: openai)
PROVIDER=openai

# ── OpenAI ─────────────────────────────────────────────
# OpenAI-compatible API Key (required when PROVIDER=openai)
OPENAI_API_KEY=sk-xxx

# API Base URL (required for third-party relays)
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Anthropic ──────────────────────────────────────────
# Anthropic API Key (required when PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# ── Common ─────────────────────────────────────────────
# Model name (default: gpt-4o for openai, claude-sonnet-4-20250514 for anthropic)
MODEL_NAME=gpt-4o

# Max agent steps (default: 15)
MAX_STEPS=15

# Headless browser mode (default: false)
HEADLESS=false

# Screenshot output directory (optional)
SCREENSHOT_DIR=./screenshots
