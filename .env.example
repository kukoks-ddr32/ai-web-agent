# OpenAI-compatible API Key (required)
OPENAI_API_KEY=sk-xxx

# API Base URL (required for third-party relays)
OPENAI_BASE_URL=https://api.openai.com/v1

# Model name (default: gpt-4o)
MODEL_NAME=gpt-4o

# Max agent steps (default: 15)
MAX_STEPS=15

# Headless browser mode (default: false)
HEADLESS=false

# Screenshot output directory (optional)
SCREENSHOT_DIR=./screenshots
